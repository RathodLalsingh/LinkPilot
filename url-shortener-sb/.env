APPLICATION_NAME=url-shortener-sb

DATABASE_URL=jdbc:postgresql://localhost:5432/url_shortener
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=root
DATABASE_DRIVER=org.postgresql.Driver

JPA_DDL_AUTO=update
JPA_SHOW_SQL=true
JPA_FORMAT_SQL=true
DATABASE_DIALECT=org.hibernate.dialect.PostgreSQLDialect

JWT_SECRET=MySuperSecretJwtKeyForSpringBootApplication2026Secure123456789
JWT_EXPIRATION=172800000

SPRING_SECURITY_LOG_LEVEL=DEBUG
URL_SHORTENER_LOG_LEVEL=DEBUG
SPRING_WEB_LOG_LEVEL=DEBUG

FRONTEND_URL=http://localhost:5173
